        <CheckItem Challenge="STBY BATT Switch" Response="OFF" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="OFF (when landing is assured)" />
        <CheckItem Challenge="Doors" Response="UNLATCH PRIOR TO TOUCHDOWN" />
        <CheckItem Challenge="Touchdown" Response="SLIGHTLY TAIL LOW" />
        <CheckItem Challenge="Mixture Control" Response="IDLE CUTOFF (pull full out)" />
        <CheckItem Challenge="MAGNETOS Switch" Response="OFF" />
        <CheckItem Challenge="Brakes" Response="APPLY HEAVILY" />
      </Section>
      <Section Name="Ditching">
        <CheckItem Challenge="ELT" Response="ACTIVATE" />
        <CheckItem Challenge="Radio" Response="TRANSMIT MAYDAY and SQUAWK 7700" />
        <CheckItem Challenge="Heavy Objects" Response="SECURE OR JETTISON (if possible)" />
        <CheckItem Challenge="Pilot and Passenger Seat Backs" Response="MOST UPRIGHT POSITION" />
        <CheckItem Challenge="Seats and Belts" Response="SECURE" />
        <CheckItem Challenge="Flaps" Response="20° - FULL" />
        <CheckItem Challenge="Power" Response="ESTABLISH 300 FT/MIN DESCENT AT 55 KIAS. If no power is available, approach at 70 KIAS with Flaps UP or at 65 KIAS with Flaps 10°." />
        <CheckItem Challenge="Approach" Response="High Winds, Heavy Seas- INTO THE WIND Light Winds, Heavy Swells - PARALLEL TO SWELLS" />
        <CheckItem Challenge="Cabin Doors" Response="UNLATCH" />
        <CheckItem Challenge="Touchdown" Response="LEVEL ATTITUDE AT ESTABLISHED RATE OF DESCENT" />
        <CheckItem Challenge="Face" Response="CUSHION AT TOUCHDOWN (with folded coat)" />
        <CheckItem Challenge="Airplane" Response="EVACUATE THROUGH CABIN DOORS" />
        <CheckItem Challenge="Life Vests and Raft" Response="INFLATE WHEN CLEAR OF AIRPLANE" />
      </Section>
    </Checklist>
    <Checklist Name="Fires (POH)" FlightPhase="Emergency">
      <Section Name="During start on ground">
        <CheckItem Challenge="MAGNETOS Switch" Response="START (continue cranking to start the engine)" />
        <CheckItem Challenge="IF ENGINE STARTS" Response="-" />
        <CheckItem Challenge="Power" Response="1800 RPM (for a few minutes)" />
        <CheckItem Challenge="Engine" Response="SHUTDOWN (inspect for damage)" />
        <CheckItem Challenge="IF ENGINE FAILS TO START" Response="-" />
        <CheckItem Challenge="Throttle Control" Response="FULL (push full in)" />
        <CheckItem Challenge="Mixture Control" Response="IDLE CUTOFF (pull full out)" />
        <CheckItem Challenge="MAGNETOS Switch" Response="START (continue cranking)" />
        <CheckItem Challenge="FUEL SHUTOFF Valve" Response="OFF (pull full out)" />
        <CheckItem Challenge="FUEL PUMP Switch" Response="OFF" />
        <CheckItem Challenge="MAGNETOS Switch" Response="OFF" />
        <CheckItem Challenge="STBY BATT Switch" Response="OFF" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="OFF" />
        <CheckItem Challenge="Engine" Response="SECURE" />
        <CheckItem Challenge="Parking Brake" Response="RELEASE" />
        <CheckItem Challenge="Fire Extinguisher" Response="OBTAIN (have ground attendants obtain if not installed)" />
        <CheckItem Challenge="Airplane" Response="EVACUATE" />
        <CheckItem Challenge="Fire" Response="EXTINGUISH (using fire extinguisher, wool blanket, or dirt)" />
        <CheckItem Challenge="Fire Damage" Response="INSPECT (repair or replace damaged components and/or wiring before conducting another flight)" />
      </Section>
      <Section Name="Engine fire in flight">
        <CheckItem Challenge="Mixture Control" Response="IDLE CUTOFF (pull full out)" />
        <CheckItem Challenge="FUEL SHUTOFF Valve" Response="OFF (pull full out)" />
        <CheckItem Challenge="FUEL PUMP Switch" Response="OFF" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="OFF" />
        <CheckItem Challenge="Cabin Vents" Response="OPEN (as needed)" />
        <CheckItem Challenge="CABIN HT and CABIN AIR Control Knobs" Response="OFF (push full in) (to avoid drafts)" />
        <CheckItem Challenge="Airspeed" Response="100 KIAS (If fire is not extinguished, increase glide speed to find an airspeed, within airspeed limitations, which will provide an incombustible mixture)" />
        <CheckItem Challenge="Forced Landing" Response="EXECUTE (refer to EMERGENCY LANDING WITHOUT ENGINE POWER)" />
      </Section>
      <Section Name="Electrical fire in flight">
        <CheckItem Challenge="STBY BATT Switch" Response="OFF" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="OFF" />
        <CheckItem Challenge="Cabin Vents" Response="CLOSED (to avoid drafts)" />
        <CheckItem Challenge="CABIN HT and CABIN AIR Control Knobs" Response="OFF (push full in) (to avoid drafts)" />
        <CheckItem Challenge="Fire Extinguisher" Response="ACTIVATE (if available)" />
        <CheckItem Challenge="AVIONICS Switch (BUS 1 and BUS 2)" Response="OFF" />
        <CheckItem Challenge="All Other Switches (except MAGNETOS switch)" Response="OFF" />
        <CheckItem Challenge="AFTER THE FIRE EXTINGUISHER HAS BEEN USED, MAKE SURE THAT THE FIRE IS EXTINGUISHED BEFORE EXTERIOR AIR IS USED TO REMOVE SMOKE FROM THE CABIN." Response="OK" />
        <CheckItem Challenge="Cabin Vents" Response="OPEN (when sure that fire is completely extinguished)" />
        <CheckItem Challenge="CABIN HT and CABIN AIR Control Knobs" Response="ON (pull full out) (when sure that fire is completely extinguished)" />
        <CheckItem Challenge="IF FIRE HAS BEEN EXTINGUISHED AND ELECTRICAL POWER IS NECESSARY FOR CONTINUED FLIGHT TO NEAREST SUITABLE AIRPORT OR LANDING AREA" Response="OK" />
        <CheckItem Challenge="Circuit Breakers" Response="CHECK (for OPEN circuit(s), do not reset)" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="ON" />
        <CheckItem Challenge="STBY BATT Switch" Response="ARM" />
        <CheckItem Challenge="AVIONICS Switch (BUS 1)" Response="ON" />
        <CheckItem Challenge="AVIONICS Switch (BUS 2)" Response="ON" />
      </Section>
      <Section Name="Cabin fire">
        <CheckItem Challenge="STBY BATT Switch" Response="OFF" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="OFF" />
        <CheckItem Challenge="Cabin Vents" Response="CLOSED (to avoid drafts)" />
        <CheckItem Challenge="CABIN HT and CABIN AIR Control Knobs" Response="OFF (push full in) (to avoid drafts)" />
        <CheckItem Challenge="Fire Extinguisher" Response="ACTIVATE (if available)" />
        <CheckItem Challenge="Cabin Vents" Response="OPEN (when sure that fire is completely extinguished)" />
        <CheckItem Challenge="CABIN HT and CABIN AIR Control Knobs" Response="ON (pull full out) (when sure that fire is completely extinguished)" />
        <CheckItem Challenge="Land the airplane as soon as possible to inspect for damage" Response="EXECUTE" />
      </Section>
      <Section Name="Wing fire">
        <CheckItem Challenge="LAND and TAXI Light Switches" Response="OFF" />
        <CheckItem Challenge="NAV Light Switch" Response="OFF" />
        <CheckItem Challenge="STROBE Light Switch" Response="OFF" />
        <CheckItem Challenge="PITOT HEAT Switch" Response="OFF" />
      </Section>
    </Checklist>
    <Checklist Name="Landing (POH)" FlightPhase="DuringFlight">
      <Section Name="Normal Landing">
        <CheckItem Challenge="Airspeed" Response="65- 75 KIAS (Flaps UP)" />
        <CheckItem Challenge="Flaps" Response="AS DESIRED(UP- 10° below 110 KIAS) (10°- FULL below 85 KIAS)" />
        <CheckItem Challenge="Airspeed" Response="60- 70 KIAS (Flaps FULL)" />
        <CheckItem Challenge="Elevator Trim Control" Response="ADJUST" />
        <CheckItem Challenge="Touchdown" Response="MAIN WHEELS FIRST" />
        <CheckItem Challenge="Landing Roll" Response="LOWER NOSEWHEEL GENTLY" />
        <CheckItem Challenge="Braking" Response="MINIMUM REQUIRED" />
      </Section>
      <Section Name="Short Field Landing">
        <CheckItem Challenge="Airspeed" Response="65- 75 KIAS (Flaps UP)" />
        <CheckItem Challenge="Flaps" Response="FULL" />
        <CheckItem Challenge="Airspeed" Response="61 KIAS (until flare)" />
        <CheckItem Challenge="Elevator Trim Control" Response="ADJUST" />
        <CheckItem Challenge="Power" Response="REDUCE TO IDLE (as obstacle is cleared)" />
        <CheckItem Challenge="Touchdown" Response="MAIN WHEELS FIRST" />
        <CheckItem Challenge="Brakes" Response="APPLY HEAVILY" />
        <CheckItem Challenge="Flaps" Response="UP" />
      </Section>
      <Section Name="Balked Landing">
        <CheckItem Challenge="Throttle Control" Response="FULL (push full in)" />
        <CheckItem Challenge="Flaps" Response="RETRACT to 20°" />
        <CheckItem Challenge="Climp Speed" Response="60 KIAS" />
        <CheckItem Challenge="Flaps" Response="10° (as obstacle is cleared), then UP (after reaching a safe altitude and 65 KIAS)" />
      </Section>
      <Section Name="After Landing">
        <CheckItem Challenge="Flaps" Response="UP" />
      </Section>
    </Checklist>
    <Checklist Name="Securing Airplane (POH)" FlightPhase="Postflight">
      <Section Name="-">
        <CheckItem Challenge="Parking Brake" Response="SET" />
        <CheckItem Challenge="Throttle Control" Response="IDLE (pull full out)" />
        <CheckItem Challenge="Electrical Equipment" Response="OFF" />
        <CheckItem Challenge="AVIONICS Switch (BUS 1 and BUS 2)" Response="OFF" />
        <CheckItem Challenge="Mixture Control" Response="IDLE CUTOFF (pull full out)" />
        <CheckItem Challenge="MAGNETOS Switch" Response="OFF" />
        <CheckItem Challenge="MASTER Switch (ALT and BAT)" Response="OFF" />
        <CheckItem Challenge="STBY BATT Switch" Response="OFF" />
        <CheckItem Challenge="Control Lock" Response="INSTALL" />
        <CheckItem Challenge="FUEL SELECTOR Valve" Response="LEFT or RIGHT (to prevent crossfeeding between tanks)" />
      </Section>
    </Checklist>
  </ChecklistBundle>
</Aircraft>